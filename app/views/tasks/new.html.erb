<h1 class="mb-4">New Task</h1>

<%= render "form", task: @task %>


<%= form_with model: @task do |f| %>
  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :details %>
    <%= f.text_area :details %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
