<h1><%= @task.title %></h1>

<p class="lead">
  <%= @task.details %>
</p>

<p>
  <% if @task.completed %>
    <span class="badge bg-success">Completed</span>
  <% else %>
    <span class="badge bg-warning text-dark">Not completed</span>
  <% end %>
</p>

<div class="mt-4">
  <%= link_to "Edit", edit_task_path(@task), class: "btn btn-primary" %>

  <%= link_to "Back",
      tasks_path,
      class: "btn btn-secondary" %>
</div>
